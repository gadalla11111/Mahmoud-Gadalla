{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "CODEX_CLI=1 bash \"${PLUGIN_ROOT:-$CLAUDE_PLUGIN_ROOT}/hooks/scripts/pre-tool-trace.sh\"",
            "timeout": 3,
            "statusMessage": "alibabacloud trace: pre"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "CODEX_CLI=1 bash \"${PLUGIN_ROOT:-$CLAUDE_PLUGIN_ROOT}/hooks/scripts/post-tool-trace.sh\"",
            "timeout": 15,
            "statusMessage": "alibabacloud trace: post"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CODEX_CLI=1 bash \"${PLUGIN_ROOT:-$CLAUDE_PLUGIN_ROOT}/hooks/scripts/prompt-trace.sh\"",
            "timeout": 5,
            "statusMessage": "alibabacloud trace: prompt"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CODEX_CLI=1 bash \"${PLUGIN_ROOT:-$CLAUDE_PLUGIN_ROOT}/hooks/scripts/stop-turn-increment.sh\"",
            "timeout": 15,
            "statusMessage": "alibabacloud trace: stop"
          }
        ]
      }
    ]
  }
}
