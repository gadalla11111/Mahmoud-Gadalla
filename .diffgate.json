{
  "testCommand": null,
  "gate": {
    "mode": "working",
    "failOn": "orange"
  },
  "ai": {
    "enabled": false,
    "model": "claude-sonnet-4-6",
    "apiKeyEnv": "ANTHROPIC_API_KEY"
  },
  "deprecated": [
    {
      "pattern": "OldService.legacyMethod",
      "replacedBy": "NewService.method",
      "author": "Your Team",
      "pr": "PR #000"
    }
  ],
  "customPatterns": [
    {
      "id": "no-direct-process-env",
      "tier": "yellow",
      "pattern": "process\\.env\\.",
      "message": "Read config through the typed config module, not process.env directly."
    }
  ],
  "rules": {
    "db-schema-destructive": { "tier": "yellow" }
  },
  "guidelines": {
    "enabled": true,
    "autoDetect": true,
    "maxDepth": 3,
    "tier": "yellow",
    "blocking": false,
    "evaluator": "auto"
  },
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/*.ipynb",
    "anthropic_skills/**",
    "claude_agent_sdk/belief-gate/docs/**",
    "claude_agent_sdk/harness-primitives/**",
    "financial_services/**",
    "tools/claude-for-foundation-models/**",
    "tools/jetbrains-plugin-lib/**",
    "tools/starter-workflows/**",
    "tools/fastled/**",
    "tools/diffgate/**",
    "tools/memex/**",
    "agent-instructions/**",
    "tokslayer/**",
    "claude-code-setup/**",
    "layrr/**",
    "claude-code-queue/**",
    "custom-instructions/**",
    "cv-optimizer-claude/**",
    "garden-skills/**",
    "skills-workspace/**",
    "agent-toolkit/**",
    "rulebook-ai/**",
    "ClaudeForge/**",
    "generator/**",
    "cc-context-awareness/**",
    "hardstop/**",
    "routeros-skills/**",
    "idstack/**",
    "nuclear-grade-context-engineering/**",
    "open-design/**",
    "taste-skill/**",
    "ui-ux-pro-max-skill/**",
    "claude-quickstarts/**",
    "Flare/**",
    "financial-services/**",
    "anthropics-skills/**",
    "ruflo/**"
  ]
}
